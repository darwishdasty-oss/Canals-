<?xml version='1.0' encoding='utf-8'?>
<widget id="com.abbas.canals.standalone" version="1.4.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Canals Workbench</name>
    <description>Hydraulic engineering calculator - works offline</description>
    <author email="abbas@example.com" href="https://github.com/abbas">
        Abbas A. Hebah
    </author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="file://*/*" />
    <preference name="DisallowOverscroll" value="true" />
    <preference name="android-minSdkVersion" value="24" />
    <preference name="android-targetSdkVersion" value="34" />
    <preference name="Orientation" value="default" />
    <preference name="BackgroundColor" value="#003366" />
    <preference name="AndroidInsecureFileModeEnabled" value="true" />
    <preference name="MixedContentMode" value="0" />
    <icon density="ldpi" src="www/icon.png" />
    <icon density="mdpi" src="www/icon.png" />
    <icon density="hdpi" src="www/icon.png" />
    <icon density="xhdpi" src="www/icon.png" />
    <icon density="xxhdpi" src="www/icon.png" />
    <icon density="xxxhdpi" src="www/icon.png" />
</widget>
